{
  "name": "markdown-preview",
  "private": true,
  "publisher": "tmux-server",
  "version": "1.0.0",
  "displayName": "Markdown Preview",
  "description": "Built-in rendered Markdown preview (bundled — see extensions/build.mjs).",
  "icon": "./icon.svg",
  "contributes": {
    "configuration": {
      "title": "Markdown Preview",
      "properties": {
        "markdown.previewFontSize": {
          "type": "integer",
          "default": 14,
          "minimum": 10,
          "maximum": 24,
          "description": "Font size (px) for the rendered Markdown preview body."
        }
      }
    }
  },
  "tmuxServer": {
    "client": "./dist/client.js"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1"
  }
}
